# Better Auth encryption secret (min 32 chars). Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Base URL of your Next.js app (server-side, read by Better Auth)
BETTER_AUTH_URL="http://localhost:3000"

# Base URL of your Next.js app (client-side, used by auth-client)
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Go API URL (server-side — used by app/api/[...path] proxy route)
GO_API_URL="http://localhost:8080"

# Go API URL (client-side — used by lib/go-api-client.ts)
NEXT_PUBLIC_GO_API_URL="http://localhost:8080"

# Neon Postgres connection string
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
